      "settings": {
        "foreground": "#C77DBB"
      }
    },
    {
      "name": "GraphQL fragment",
      "scope": ["variable.fragment.graphql", "entity.name.fragment.graphql"],
      "settings": {
        "foreground": "#56A8F5"
      }
    },
    {
      "name": "GraphQL types / punctuation",
      "scope": [
        "meta.arguments.graphql",
        "support.type.graphql",
        "punctuation.operation.graphql",
        "variable.parameter.graphql",
        "meta.brace.round.graphql",
        "punctuation.colon.graphql",
        "punctuation.assignment.graphql",
        "string.unquoted.alias.graphql",
        "support.type.builtin.graphql"
      ],
      "settings": {
        "foreground": "#BCBEC4"
      }
    },
    {
      "name": "GraphQL enum",
