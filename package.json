{
  "name": "the-islands-theme",
  "displayName": "The Islands Theme",
  "version": "1.1.0",
  "publisher": "butov-dev",
  "license": "MIT",
  "description": "The Islands Theme for VS Code — Dark, Light, and Darcula variants inspired by the JetBrains Islands theme, the new default look for JetBrains IDEs.",
  "scripts": {
    "lint": "prettier src --write",
    "vsce-package": "vsce package -o ./bin/theme.vsix",
    "vsce-publish": "vsce publish"
  },
  "galleryBanner": {
    "color": "#191A1C",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "maintainers": ["Ruslan Butov"],
  "categories": ["Themes"],
  "keywords": [
    "theme",
    "color-theme",
    "dark",
    "light",
    "darcula",
    "jetbrains",
    "islands",
    "islands dark",
    "islands light",
    "islands darcula",
    "intellij",
    "webstorm",
    "phpstorm",
    "pycharm",
    "javascript",
    "typescript",
    "php",
    "graphql",
    "dark theme",
    "light theme",
    "cursor"
  ],
  "homepage": "https://github.com/rbutov/vscode-the-islands-theme",
  "contributes": {
    "themes": [
      {
        "label": "Islands Dark",
        "uiTheme": "vs-dark",
        "path": "./src/islands-dark.json"
      },
      {
        "label": "Islands Light",
        "uiTheme": "vs",
        "path": "./src/islands-light.json"
      },
      {
        "label": "Islands Darcula",
        "uiTheme": "vs-dark",
        "path": "./src/islands-darcula.json"
      }
    ]
  },
  "icon": "./images/icon.png",
  "bugs": {
    "url": "https://github.com/rbutov/vscode-the-islands-theme/issues",
    "email": "support@butov.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rbutov/vscode-the-islands-theme.git"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "prettier": "^3.9.5"
  }
}
